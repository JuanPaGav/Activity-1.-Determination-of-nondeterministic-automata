digraph Automata {
  rankdir=LR;

  node [shape = point];
  qi;

  node [shape = circle];
  n_0 [label="0"];
  n_1 [label="1"];
  n_2 [label="2"];

  node [shape = doublecircle];
  n_3 [label="3"];

  qi -> n_0;

  n_0 -> n_0 [label="a"];
  n_0 -> n_1 [label="a"];
  n_0 -> n_0 [label="b"];
  n_1 -> n_2 [label="b"];
  n_2 -> n_3 [label="b"];
}
